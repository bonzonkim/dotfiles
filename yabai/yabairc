yabai -m rule --add app="^Calendar$" manage=off
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="^Dictionary$" manage=off
yabai -m rule --add app="^LINE$" manage=off
yabai -m rule --add app="^Mail$" manage=off
yabai -m rule --add app="^Scheduler$" manage=off

yabai -m config active_window_border_color   0xff775759
yabai -m config normal_window_border_color   0xff555555

# --- Per-display top padding (landscape vs portrait displays) ---

setup_padding() {
  LANDSCAPE_TOP=6
  PORTRAIT_TOP=35

  yabai -m query --displays | jq -c '.[]' | while read -r display; do
    id=$(echo "$display" | jq -r '.id')
    width=$(echo "$display" | jq -r '.frame.w | floor')
    height=$(echo "$display" | jq -r '.frame.h | floor')

    if [ "$width" -gt "$height" ]; then
      top_padding=$LANDSCAPE_TOP
    else
      top_padding=$PORTRAIT_TOP
    fi

    yabai -m config --display "$id" top_padding "$top_padding"

    yabai -m query --spaces --display "$id" | jq -r '.[].index' | while read -r space; do
      yabai -m config --space "$space" top_padding "$top_padding"
    done
  done
}

setup_padding

