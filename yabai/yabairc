# --- Per-display top padding (MacBook vs external monitors) ---

setup_padding() {
  # Only top padding is adjusted per-display
  MAC_TOP=1
  DELL_TOP=36

  yabai -m query --displays | jq -c '.[]' | while read -r display; do
    id=$(echo "$display" | jq '.id')
    width=$(echo "$display" | jq '.frame.w')

    # convert width to integer (handles floats like 2056.0000)
    w_int=$(echo "$width" | awk '{printf("%d", $1)}')

    # Treat narrow displays (<=2100px) as the built-in MacBook display
    if [ "$w_int" -le 2100 ]; then
      yabai -m config --display "$id" top_padding $MAC_TOP

      yabai -m query --spaces --display "$id" | jq -r '.[].index' | while read -r s; do
        yabai -m config --space "$s" top_padding $MAC_TOP
      done
    else
      yabai -m config --display "$id" top_padding $DELL_TOP

      yabai -m query --spaces --display "$id" | jq -r '.[].index' | while read -r s; do
        yabai -m config --space "$s" top_padding $DELL_TOP
      done
    fi
  done
}

setup_padding

